@{
    var customers = ViewBag.Customers as List<MigrationTestApp.Models.Customer>;
    var products = ViewBag.Products as List<MigrationTestApp.Models.Product>;
}

<h1>Create Order</h1>

<form asp-action="Create" enctype="multipart/form-data" method="post">
    <div>
        <label>Customer</label>
        <select name="customerId">
            @foreach (var c in customers!)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div>
    <div>
        <label>Product</label>
        <select name="productId">
            @foreach (var p in products!)
            {
                <option value="@p.Id">@p.Name (@p.Price)</option>
            }
        </select>
    </div>
    <div>
        <label>Quantity</label>
        <input type="number" name="quantity" value="1" min="1" />
    </div>
    <div>
        <label>Invoice File (optional)</label>
        <input type="file" name="invoiceFile" />
    </div>
    <button type="submit">Create</button>
</form>